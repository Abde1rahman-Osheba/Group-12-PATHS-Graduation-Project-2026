# PATHS — root docker-compose overrides.
# Copy to `.env` (same dir as docker-compose.yml) and edit as needed.
# Every value here has a sane default baked into docker-compose.yml, so the
# stack runs with NO .env at all; this file just documents what you can tune.

# ── App ────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
# Comma-separated browser origins allowed to call the backend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CHANGE THIS for any non-local deployment (APP_ENV=production refuses the default).
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-SECRET

# ── PostgreSQL (+ Apache AGE) ──────────────────────────────────────────
POSTGRES_DB=paths_db
POSTGRES_USER=paths_user
POSTGRES_PASSWORD=change_me
AGE_GRAPH_NAME=paths_graph

# ── Frontend → backend URL (baked into the web image at build time) ────
# Must be reachable from the user's BROWSER, i.e. the published host port.
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── Optional: OpenRouter (LLM scoring / decision support) ──────────────
# Leave blank to use the deterministic offline scoring fallback.
OPENROUTER_API_KEY=
