# ── Application ──────────────────────────────────────────
APP_NAME=PATHS Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=true
# Web UI (Next default :3000, Vite :5173) — comma-separated
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ── PostgreSQL ──────────────────────────────────────────
# For Uvicorn on your PC, use localhost; hostname "postgres" is for the backend *container* on docker-compose only.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=paths_db
POSTGRES_USER=paths_user
# Default must match backend/docker-compose.yml (POSTGRES_PASSWORD: change_me)
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://paths_user:change_me@localhost:5432/paths_db

# ── Apache AGE ──────────────────────────────────────────
AGE_GRAPH_NAME=paths_graph
AGE_SCHEMA=ag_catalog

# ── Qdrant ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Legacy chunked CV collection (kept for backward compatibility)
QDRANT_COLLECTION_CV=candidate_cv_chunks
QDRANT_COLLECTION_VECTOR_SIZE=768
# Spec-compliant unified collections — one vector per candidate / per job
QDRANT_CANDIDATE_COLLECTION=paths_candidates
QDRANT_JOB_COLLECTION=paths_jobs

# ── Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Embedding (provider-agnostic aliases) ───────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_VERSION=v1

# ── OpenRouter / Llama scoring agent ────────────────────
# Backend candidate-job scoring service (see DATABASE_INTEGRATION.md
# and PATHS_Candidate_Job_Scoring_Service_Cursor_Instructions.md).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_REFERER=https://paths.local
OPENROUTER_APP_TITLE=PATHS Scoring Agent
# Decision Support System (Llama 3.2 8B class models — template IDs for OpenRouter)
OPENROUTER_DSS_MODEL=meta-llama/llama-3.2-8b-instruct
OPENROUTER_DEVELOPMENT_MODEL=meta-llama/llama-3.2-8b-instruct
OPENROUTER_OUTREACH_MODEL=meta-llama/llama-3.2-8b-instruct
DECISION_SUPPORT_ENABLED=true
DSS_OPENROUTER_TIMEOUT_SECONDS=120

SCORING_SERVICE_ENABLED=true
SCORING_AGENT_WEIGHT=0.65
SCORING_VECTOR_WEIGHT=0.35
SCORING_MIN_RELEVANCE_THRESHOLD=0.45
SCORING_MAX_JOBS_PER_CANDIDATE=20
SCORING_MODEL_TEMPERATURE=0.1
SCORING_MODEL_MAX_TOKENS=1200
SCORING_REQUEST_TIMEOUT_SECONDS=60
SCORING_PROMPT_VERSION=v1
SCORING_ALLOW_OFFLINE_FALLBACK=true

# Spec aliases for the unified Qdrant collections
QDRANT_COLLECTION_CANDIDATES=paths_candidates

# ── Organization-side candidate search + outreach ───────
ORG_MATCHING_ENABLED=true
ORG_MATCHING_DEFAULT_TOP_K=3
ORG_MATCHING_MAX_TOP_K=20
ORG_MATCHING_MAX_CANDIDATES_PER_RUN=200
ORG_MATCHING_REQUIRE_HUMAN_APPROVAL=true
ORG_SCORING_AGENT_WEIGHT=0.65
ORG_SCORING_VECTOR_WEIGHT=0.35
ORG_SCORING_MIN_RELEVANCE_THRESHOLD=0.45

# LLM provider abstraction (openrouter|ollama)
LLM_PROVIDER=openrouter
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
LLM_STREAMING_ENABLED=true
LLM_ALLOW_FALLBACK_TO_OLLAMA=true
OLLAMA_MODEL=llama3.1:8b

# CSV / CV download safety
ORG_CSV_MAX_ROWS=500
ORG_CV_DOWNLOAD_TIMEOUT_SECONDS=30
ORG_CV_MAX_FILE_SIZE_MB=10
ORG_CV_ALLOWED_CONTENT_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,text/plain
ORG_CV_BLOCK_PRIVATE_NETWORKS=true

# Outreach
OUTREACH_ENABLED=true
OUTREACH_REQUIRE_APPROVAL=true
OUTREACH_FROM_EMAIL=
OUTREACH_FROM_NAME=PATHS Recruitment
OUTREACH_REPLY_DEADLINE_DAYS=3
OUTREACH_DEFAULT_BOOKING_LINK=
OUTREACH_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Optional MCP support
MCP_ENABLED=false
MCP_GOOGLE_CALENDAR_ENABLED=false
MCP_GMAIL_ENABLED=false

# ── Hourly Job Scraper (Job_Scraper-main wrapper) ───────
# Disabled by default. Requires Playwright + Firefox: see
# DATABASE_INTEGRATION.md / README.md for setup.
JOB_SCRAPER_ENABLED=true
# Aliases (same as JOB_SCRAPER_* — 5 jobs max every 10 minutes when importer enabled)
JOB_IMPORTER_ENABLED=true
JOB_IMPORTER_INTERVAL_MINUTES=10
JOB_IMPORTER_JOBS_PER_RUN=5
JOB_SCRAPER_INTERVAL_MINUTES=60
JOB_SCRAPER_BATCH_SIZE=5
JOB_SCRAPER_RUN_ON_STARTUP=true
JOB_SCRAPER_SOURCE=linkedin
JOB_SCRAPER_TIMEOUT_SECONDS=120
JOB_SCRAPER_MAX_PAGES_PER_RUN=1
JOB_SCRAPER_LOG_LEVEL=INFO
JOB_SCRAPER_MODULE_PATH=../Job_Scraper-main
JOB_SCRAPER_DATA_FILE=../Job_Scraper-main/data/Data.xlsx
JOB_SCRAPER_COMPANIES_PER_RUN=8
JOB_SCRAPER_HEADLESS=true
# Set to true to skip browser launch (useful in tests / dev without Playwright)
JOB_SCRAPER_STUB=false
JOB_SCRAPER_LOCK_NAME=paths_job_scraper_hourly_import
# Optional aliases — same scheduler; LINKEDIN_JOBS_PER_HOUR is capped at 10 per run
ENABLE_SCHEDULER=true
LINKEDIN_SCRAPER_ENABLED=true
LINKEDIN_JOBS_PER_HOUR=10
LINKEDIN_JOBS_PER_RUN=5
LINKEDIN_SCRAPER_INTERVAL_MINUTES=60
# Spec aliases (kept for forward compatibility — these point at the
# unified collection name the rest of the backend already uses):
QDRANT_COLLECTION_JOBS=paths_jobs
EMBEDDING_MODEL_NAME=nomic-embed-text

# ── Ingestion ───────────────────────────────────────────
UPLOAD_DIR=./uploads
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# ── Authentication / JWT ────────────────────────────────
# Development: copy to backend/.env and replace with a random string, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Production: APP_ENV=production refuses the default sentinel (see app/core/config.py).
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Interview intelligence (HITL; AI recommends only) ─
INTERVIEW_INTELLIGENCE_ENABLED=true
# Optional: Google Calendar + Meet (service account JSON path)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# Local-only path to a service account JSON (never commit the file; keep under backend/secrets/).
GOOGLE_CALENDAR_SERVICE_ACCOUNT_FILE=
GOOGLE_CALENDAR_ID=primary
# Domain-wide delegation: workspace user the service account acts as
GOOGLE_WORKSPACE_IMPERSONATE_USER=

# ── Platform admins ─────────────────────────────────────
# The five platform admin users. Real emails/passwords are NEVER committed.
# Set them in your local .env, NOT here. Names are fixed; only email/password
# are placeholders. Run `python scripts/seed_platform_admins.py` after editing
# .env to create or update the rows. The script is idempotent and refuses to
# silently flip any existing user to platform_admin without explicit consent.
PLATFORM_ADMIN_1_NAME=Osama El-Swesy
PLATFORM_ADMIN_1_EMAIL=
PLATFORM_ADMIN_1_PASSWORD=

PLATFORM_ADMIN_2_NAME=Abdelrahman Atef
PLATFORM_ADMIN_2_EMAIL=
PLATFORM_ADMIN_2_PASSWORD=

PLATFORM_ADMIN_3_NAME=Ahmed Ashraf
PLATFORM_ADMIN_3_EMAIL=
PLATFORM_ADMIN_3_PASSWORD=

PLATFORM_ADMIN_4_NAME=Ahmed Alaa
PLATFORM_ADMIN_4_EMAIL=
PLATFORM_ADMIN_4_PASSWORD=

PLATFORM_ADMIN_5_NAME=Youssef Abousrewa
PLATFORM_ADMIN_5_EMAIL=
PLATFORM_ADMIN_5_PASSWORD=
